{
  "schemaVersion": 1,
  "id": "babyzombieaddons",
  "version": "${version}",

  "name": "BabyzombieAddons",
  "description": "Hypixel SkyBlock QoL utilities",
  "authors": ["baby__zombie","TryToFeel"],
  "contact": {
    "homepage": "https://github.com/babyzombie/BabyzombieAddons",
    "sources": "https://github.com/babyzombie/BabyzombieAddons",
    "issues": "https://github.com/babyzombie/BabyzombieAddons/issues"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.gitee": "https://gitee.com/Bluesky-kk/BabyzombieAddons"
      }
    }
  },

  "license": "LGPL-3.0",
  "icon": "assets/babyzombieaddons/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": ["top.babyzombie.addons.BabyzombieAddonsClient"],
    "modmenu": ["top.babyzombie.addons.compatibility.modmenu.ModMenuEntry"]
  },

  "mixins": [
    {
      "config": "babyzombieaddons.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_version}",
    "minecraft": "${minecraft_version}",
    "fabric-language-kotlin": ">=1.0"
  },
  "suggests": {
    "yet-another-config-lib": ">=${yacl_mod_version}",
    "modmenu": ">=${mod_menu_mod_version}",
    "roughlyenoughitems": ">=26.1"
  }
}
