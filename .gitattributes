# 统一行分隔符为 LF
* text=auto eol=lf

# Java / Kotlin / Scala
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.scala text eol=lf

# Gradle
*.gradle text eol=lf
*.properties text eol=lf
gradlew text eol=lf

# 配置文件
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.mcmeta text eol=lf

# Shader
*.glsl text eol=lf
*.fsh text eol=lf
*.vsh text eol=lf

# Markdown / 文本
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf
.gitignore text eol=lf

# Windows 批处理文件必须用 CRLF
*.bat text eol=crlf

# 二进制文件不改动
*.jar binary
*.png binary
